.container { min-height: 100vh; padding: 20rpx; background: #f5f5f5; box-sizing: border-box; }
.create-button { margin: 0 0 20rpx; background: #1296db; color: #fff; font-size: 30rpx; border-radius: 10rpx; }
.tabs { display: flex; background: #fff; border-radius: 10rpx; margin-bottom: 20rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 22rpx 0; color: #666; font-size: 28rpx; }
.tab.active { color: #1296db; font-weight: 600; border-bottom: 4rpx solid #1296db; }
.course-card, .pagination { background: #fff; border-radius: 10rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.04); }
.card-title { display: flex; justify-content: space-between; font-size: 30rpx; font-weight: 600; color: #333; padding-bottom: 16rpx; border-bottom: 1rpx solid #eee; }
.status, .formal-status { color: #f59e0b; font-size: 24rpx; }.formal-status { color: #16a34a; }
.course-row { display: flex; justify-content: space-between; gap: 20rpx; margin-top: 16rpx; font-size: 26rpx; color: #444; }.course-row text:first-child { color: #888; flex-shrink: 0; }
.member-toggle { color: #1296db; font-size: 26rpx; padding: 20rpx 0 10rpx; }.members { border-top: 1rpx solid #eee; }.member { display: flex; flex-direction: column; gap: 8rpx; padding: 16rpx 0; color: #555; font-size: 24rpx; border-bottom: 1rpx solid #f2f2f2; }.empty-member { padding: 16rpx 0; color: #999; font-size: 24rpx; }
.actions { display: flex; justify-content: flex-end; gap: 16rpx; margin-top: 20rpx; }.actions button { margin: 0; color: #1296db; background: #e6f7ff; }.actions .danger { color: #dc2626; background: #fee2e2; }
.loading, .empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }.pagination text { display: block; text-align: center; color: #666; font-size: 26rpx; margin-bottom: 18rpx; }.page-actions { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }.page-actions button { margin: 0; background: #e6f7ff; color: #1296db; }.page-actions input { width: 90rpx; border: 1rpx solid #ddd; border-radius: 6rpx; text-align: center; padding: 8rpx; font-size: 24rpx; }
