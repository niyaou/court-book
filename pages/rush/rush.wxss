/* 畅打活动报名：背景铺满整屏 - page + 固定层双保险 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e3f2fc 0%, #eef6fc 25%, #f5f9fd 50%, #fafcfd 75%, #ffffff 100%);
}

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  font-family: -apple-system-font, "PingFang SC", "Helvetica Neue", sans-serif;
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #e3f2fc 0%, #eef6fc 25%, #f5f9fd 50%, #fafcfd 75%, #ffffff 100%);
}

/* 固定层铺满视窗，不随内容高度变化 */
.page__bg {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}
.page__bg-fill {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #e3f2fc 0%, #eef6fc 25%, #f5f9fd 50%, #fafcfd 75%, #ffffff 100%);
}
.page__bg-lines {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background-image:
    repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 100rpx,
      rgba(174, 214, 241, 0.06) 100rpx,
      rgba(174, 214, 241, 0.06) 102rpx
    );
  pointer-events: none;
}
.page__bg-glow {
  position: absolute;
  width: 120%;
  height: 420rpx;
  left: -10%;
  top: -100rpx;
  background: radial-gradient(ellipse 75% 100% at 50% 0%, rgba(144, 202, 249, 0.2) 0%, transparent 55%);
  pointer-events: none;
}
.page__bg-sparkle {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #fff;
  opacity: 0.5;
  pointer-events: none;
}
.page__bg-sparkle--1 { left: 12%; top: 22%; }
.page__bg-sparkle--2 { left: 78%; top: 18%; }
.page__bg-sparkle--3 { left: 25%; top: 48%; }
.page__bg-sparkle--4 { left: 85%; top: 52%; }
.page__bg-sparkle--5 { left: 50%; top: 35%; }

.page__head {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 32rpx;
}
.page__title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1a2b3d;
  letter-spacing: 0.04em;
  margin-bottom: 8rpx;
}
.page__subtitle {
  font-size: 26rpx;
  color: #6b8aa8;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.page__list {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}
.empty-icon {
  font-size: 64rpx;
  color: rgba(107, 138, 168, 0.25);
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #8aa3b8;
  font-weight: 400;
}

.card {
  position: relative;
  margin-bottom: 28rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 36rpx rgba(26, 43, 61, 0.06),
    0 2rpx 14rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.card:active {
  transform: scale(0.99);
  box-shadow: 0 4rpx 24rpx rgba(26, 43, 61, 0.05);
}
.card--weak {
  opacity: 0.55;
}
.card__glass {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  pointer-events: none;
}
.card--open .card__glass {
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 0 0 1rpx rgba(82, 196, 26, 0.1) inset;
}
.card--full .card__glass {
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 0 0 1rpx rgba(250, 140, 22, 0.08) inset;
}

.card__inner {
  position: relative;
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 24rpx 28rpx;
  min-height: 180rpx;
}

.card__main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

/* 首行：活动(小灰) + 活动名(粗) + 校区标签(灰底) + 状态(绿) */
.card__top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
  margin-bottom: 16rpx;
}
.card__label {
  font-size: 24rpx;
  font-weight: 400;
  color: #8a9ba8;
  flex-shrink: 0;
}
.card__activity {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a2b3d;
  flex-shrink: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card__campus-tag {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  max-width: 240rpx;
}
.card__campus-tag--0 { background: rgba(211, 47, 47, 0.18); }
.card__campus-tag--1 { background: rgba(57, 73, 171, 0.18); }
.card__campus-tag--2 { background: rgba(0, 137, 123, 0.18); }
.card__campus-tag--3 { background: rgba(56, 142, 60, 0.18); }
.card__campus-tag--4 { background: rgba(0, 151, 167, 0.18); }
.card__campus-tag--5 { background: rgba(25, 118, 210, 0.18); }
.card__campus-tag--6 { background: rgba(123, 31, 162, 0.18); }
.card__campus-tag--7 { background: rgba(194, 24, 91, 0.18); }
.card__campus-text {
  font-size: 24rpx;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}
.card__campus-text { color: #4a657a; }
.card__campus-tag--0 .card__campus-text { color: #d32f2f; }
.card__campus-tag--1 .card__campus-text { color: #3949ab; }
.card__campus-tag--2 .card__campus-text { color: #00897b; }
.card__campus-tag--3 .card__campus-text { color: #388e3c; }
.card__campus-tag--4 .card__campus-text { color: #0097a7; }
.card__campus-tag--5 .card__campus-text { color: #1976d2; }
.card__campus-tag--6 .card__campus-text { color: #7b1fa2; }
.card__campus-tag--7 .card__campus-text { color: #c2185b; }
/* 状态按钮：与立即报名同风格，渐变+光泽，颜色随状态 */
.card__status {
  flex-shrink: 0;
  width: 148rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 50%, #2e7d32 100%);
  box-shadow:
    0 4rpx 16rpx rgba(67, 160, 71, 0.35),
    0 0 0 1rpx rgba(255, 255, 255, 0.25) inset;
}
.card__status-gloss {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.28) 0%, transparent 100%);
  border-radius: 28rpx 28rpx 0 0;
  pointer-events: none;
}
.card__status-text {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.02em;
}
.card--full .card__status {
  background: linear-gradient(135deg, #ffb74d 0%, #ff9800 50%, #f57c00 100%);
  box-shadow:
    0 4rpx 16rpx rgba(255, 152, 0, 0.35),
    0 0 0 1rpx rgba(255, 255, 255, 0.25) inset;
}
.card--ended .card__status,
.card--cancelled .card__status {
  background: linear-gradient(135deg, #90a4ae 0%, #607d8b 50%, #455a64 100%);
  box-shadow:
    0 4rpx 16rpx rgba(96, 125, 139, 0.3),
    0 0 0 1rpx rgba(255, 255, 255, 0.2) inset;
}

.card__row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}
.card__row:last-child {
  margin-bottom: 0;
}
.card__ico {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.card__ico--time {
  background: rgba(24, 144, 255, 0.12);
  flex-direction: column;
  gap: 0;
  justify-content: center;
  align-items: center;
}
.card__ico-sand-top,
.card__ico-sand-bottom {
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
}
.card__ico-sand-top {
  border-top: 8rpx solid #1890ff;
  margin-bottom: -2rpx;
}
.card__ico-sand-bottom {
  border-bottom: 8rpx solid #1890ff;
}
.card__ico--people {
  background: rgba(24, 144, 255, 0.1);
  flex-direction: row;
  gap: 4rpx;
}
.card__ico-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #1890ff;
}
.card__ico--price {
  background: rgba(250, 173, 20, 0.14);
}
.card__ico-yen {
  font-size: 22rpx;
  font-weight: 700;
  color: #d48806;
  line-height: 1;
}
.card__row-text {
  font-size: 26rpx;
  color: #4a657a;
  font-weight: 400;
  line-height: 1.4;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card__right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  flex-shrink: 0;
  padding-left: 20rpx;
  border-left: 1rpx solid rgba(0, 0, 0, 0.06);
}
.card__cta {
  width: 148rpx;
  height: 62rpx;
  border-radius: 31rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #42a5f5 0%, #1e88e5 50%, #1565c0 100%);
  box-shadow:
    0 6rpx 22rpx rgba(30, 136, 229, 0.4),
    0 0 0 1rpx rgba(255, 255, 255, 0.3) inset;
  position: relative;
  overflow: hidden;
}
.card__cta-gloss {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.28) 0%, transparent 100%);
  border-radius: 31rpx 31rpx 0 0;
  pointer-events: none;
}
.card__cta:active {
  opacity: 0.92;
}
.card__cta-text {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.04em;
}
.card__cta-arrow {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}
.card--ended .card__cta,
.card--cancelled .card__cta {
  opacity: 0.7;
}
.card--ended .card__right,
.card--cancelled .card__right {
  border-left-color: rgba(0, 0, 0, 0.04);
}

/* 底部装饰条：模拟参考图底部运动氛围 */
.page__foot {

  z-index: 1;
  padding: 16rpx 32rpx 0;
  margin-top: 12rpx;
}
.page__foot-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(174, 214, 241, 0.15) 50%, rgba(144, 202, 249, 0.12) 100%);
  border-radius: 30rpx 30rpx 0 0;
}
.page__pager {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}
.page__pager-text {
  font-size: 24rpx;
  color: #5c6f82;
}
.page__pager-btn {
  min-width: 148rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #42a5f5 0%, #1e88e5 50%, #1565c0 100%);
  box-shadow:
    0 4rpx 16rpx rgba(30, 136, 229, 0.3),
    0 0 0 1rpx rgba(255, 255, 255, 0.3) inset;
}
.page__pager-btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}
.page__pager-btn-arrow {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}
.page__pager-btn--disabled {
  opacity: 0.45;
}
