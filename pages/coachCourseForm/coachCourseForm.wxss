.container { min-height: 100vh; padding: 20rpx; box-sizing: border-box; background: #f5f5f5; }.form-card { margin-bottom: 20rpx; padding: 8rpx 24rpx; background: #fff; border-radius: 10rpx; }.field { display: flex; align-items: center; justify-content: space-between; min-height: 92rpx; border-bottom: 1rpx solid #eee; font-size: 28rpx; }.field:last-child { border: 0; }.label { color: #555; min-width: 145rpx; }.static-value, .picker-value { color: #333; text-align: right; }.picker-value { min-width: 310rpx; }.adult-field radio-group { display: flex; gap: 24rpx; font-size: 26rpx; }.vertical { display: block; padding: 20rpx 0; }.vertical textarea { width: 100%; min-height: 140rpx; margin-top: 16rpx; box-sizing: border-box; padding: 16rpx; background: #f8fafc; border-radius: 8rpx; font-size: 27rpx; }.section-title { font-size: 30rpx; font-weight: 600; padding: 18rpx 0; }.member-editor { border-top: 1rpx solid #eee; padding: 18rpx 0; }.member-header { display: flex; justify-content: space-between; color: #333; font-size: 28rpx; font-weight: 500; }.remove { color: #dc2626; font-size: 25rpx; }.member-picker { margin: 16rpx 0; color: #1296db; font-size: 26rpx; }.input-row { display: flex; align-items: center; gap: 14rpx; margin-top: 14rpx; color: #666; font-size: 26rpx; }.input-row input { flex: 1; border: 1rpx solid #ddd; border-radius: 6rpx; padding: 10rpx; text-align: right; color: #333; }.debt-tip { margin-top: 14rpx; padding: 12rpx; color: #b45309; background: #fef3c7; border-radius: 6rpx; font-size: 23rpx; }.search-box { margin: 18rpx 0; border: 1rpx solid #dbeafe; border-radius: 8rpx; overflow: hidden; }.search-box input { padding: 18rpx; font-size: 27rpx; }.search-loading, .search-result { padding: 16rpx 18rpx; border-top: 1rpx solid #eee; color: #555; font-size: 27rpx; }.search-result { color: #1296db; }.search-disabled { color: #999; font-size: 25rpx; padding: 22rpx 0; }.submit { background: #1296db; color: #fff; border-radius: 10rpx; font-size: 30rpx; margin: 32rpx 0; }
