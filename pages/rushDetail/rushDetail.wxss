/* 页面背景：浅灰蓝，仅内容区滚动，避免短内容时整页可拉 */
page { height: 100%; overflow: hidden; }
.container { min-height: 100%; padding: 24rpx; padding-bottom: 120rpx; background: #e8ecf1; overflow-y: auto; box-sizing: border-box; }

.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }

.card-overview .title { display: block; font-size: 36rpx; font-weight: 700; margin-bottom: 6rpx; }
.card-overview .subtitle { display: block; font-size: 38rpx; font-weight: 600; color: #333; margin-bottom: 14rpx; }
.card-overview .tags { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.tag { padding: 8rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; }
.tag-status { background: #e8f5e9; color: #2e7d32; }
.tag-remain { background: #fff3e0; color: #e65100; }

.detail-row { display: flex; align-items: center; margin-top: 14rpx; color: #555; font-size: 28rpx; }
.icon-wrap { width: 32rpx; height: 32rpx; border-radius: 8rpx; margin-right: 12rpx; flex-shrink: 0; }
.icon-time { background: #2196f3; }
.icon-people { background: #7c4dff; }
.icon-fee { background: #4caf50; }
.icon-doc { background: #2196f3; }

.rule-title { display: flex; align-items: center; font-size: 30rpx; font-weight: 600; color: #1a1a1a; }
.rule-title .icon-wrap { margin-right: 10rpx; }
.rule-content { color: #666; font-size: 26rpx; margin-top: 12rpx; white-space: pre-wrap; line-height: 1.5; }

.participants { display: flex; flex-wrap: wrap; gap: 24rpx; margin-top: 20rpx; }
.participant-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.participant-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: #eee; }
.participant-name { font-size: 24rpx; color: #333; }

.actions { margin-top: 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.btn { border-radius: 16rpx; font-size: 32rpx; height: 88rpx; line-height: 88rpx; }
.btn-primary { background: #1976d2; color: #fff; }
.btn-warn { background: #ff9800; color: #fff; }
.btn-danger { background: #f44336; color: #fff; }
.btn-disabled { background: #bdbdbd !important; color: #fff; }
